# 서버에만 존재. 프론트엔드에 절대 노출 금지 (FR-B1). 이 파일을 .env로 복사해 채운다.

# ── 해석 엔진 (LLM) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# claude | rule | auto(기본: 키 있으면 claude)
KIOSK_PROVIDER=auto
KIOSK_MODEL=claude-sonnet-4-6

# ── STT: CLOVA Speech (기본) ────────────────────────
# 콘솔: 도메인 > 빌더 실행 > 설정 에서 확인 (도메인: CarpeDM-LivingLab, 단문 인식)
# 예: https://clovaspeech-gw.ncloud.com/external/v1/1234/abcdefg...
CLOVA_SPEECH_INVOKE_URL=
CLOVA_SPEECH_SECRET_KEY=
# clova | gemini | auto(기본: CLOVA 키 있으면 CLOVA) | none
KIOSK_STT=auto
# CLOVA 불가 시 폴백용 (선택)
GEMINI_API_KEY=

# ── TTS: Google Cloud Text-to-Speech ────────────────
# 둘 중 하나만 설정하면 된다
GOOGLE_TTS_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=./secrets/google-service-account.json
# google | auto(기본) | none
KIOSK_TTS=auto
KIOSK_TTS_VOICE=ko-KR-Neural2-A
# 고령 친화: 또박또박 느리게 (1.0 = 보통)
KIOSK_TTS_RATE=0.9
