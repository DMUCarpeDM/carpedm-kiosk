# 서버에만 존재. 프론트엔드에 절대 노출 금지 (FR-B1). 이 파일을 .env로 복사해 채운다.

# ── 해석 엔진 (LLM) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# claude | rule | auto(기본: 키 있으면 claude)
KIOSK_PROVIDER=auto
# 비용 절약: claude-haiku-4-5-20251001 (기본 권장) / 품질 우선: claude-sonnet-4-6
KIOSK_MODEL=claude-haiku-4-5-20251001
# 규칙 우선 게이트 — 표현 사전으로 확실히 풀리는 발화는 LLM API를 부르지 않음 (비용·지연 절감)
# 0=끔 | 1(기본)=주문·확정만 규칙으로 | all=추천·거절까지 규칙으로 (절감 최대)
KIOSK_RULE_FIRST=1

# ── STT: CLOVA Speech (기본) ────────────────────────
# 콘솔: CLOVA Speech > 도메인(CarpeDM-LivingLab) > 설정 에서 Secret Key와 URL 확인.
# URL 형태에 따라 자동 판별:
#  - 단문 인식: https://clovaspeech-gw.ncloud.com/recog/v1  (비워도 이 값이 기본)
#  - 장문(로컬 파일): https://clovaspeech-gw.ncloud.com/external/v1/1234/abcd...
CLOVA_SPEECH_INVOKE_URL=https://clovaspeech-gw.ncloud.com/recog/v1
CLOVA_SPEECH_SECRET_KEY=
# (구형 CSR을 쓸 때만) AI·NAVER API 앱의 Client ID — 이 경우 SECRET_KEY에는 Client Secret
CLOVA_CLIENT_ID=
# clova | gemini | auto(기본: CLOVA 키 있으면 CLOVA) | none
KIOSK_STT=auto
# CLOVA 불가 시 폴백용 (선택)
GEMINI_API_KEY=

# ── TTS: Google Cloud Text-to-Speech ────────────────
# 둘 중 하나만 설정하면 된다
GOOGLE_TTS_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=./secrets/google-service-account.json
# google | auto(기본) | none
KIOSK_TTS=auto
KIOSK_TTS_VOICE=ko-KR-Neural2-A
# 고령 친화: 또박또박 느리게 (1.0 = 보통)
KIOSK_TTS_RATE=0.9

# ── 인체 감지 (손님이 다가오면 대기화면이 걷히고 인사) ────
# KIOSK_PRESENCE: auto(기본) | camera | pir | off
#   auto  = 라즈베리파이면 카메라를 시도(실패 시 PIR), 맥·CI에서는 자동 비활성
#   camera= 어디서나 카메라 강제 (맥에서 테스트 시. 맥은 카메라 권한 필요)
#   pir   = HC-SR501 GPIO 센서 사용
#   off   = 강제 끔
KIOSK_PRESENCE=auto
# 마지막 감지 후 '사람 있음'으로 유지할 초 (카메라)
KIOSK_PRESENCE_HOLD=6

# 카메라 방식 세부 설정
KIOSK_CAM_INDEX=0
# 얼굴 폭 / 화면 폭 비율이 이 값 이상이면 '가까이 다가옴'으로 판정 (0.18 = 폭의 18%)
# 현장에서 감지 거리가 너무 멀면 값을 올리고(예 0.25), 너무 가까워야 잡히면 내린다(예 0.12)
KIOSK_CAM_MIN_FACE=0.18
KIOSK_CAM_INTERVAL=0.4

# PIR(HC-SR501) 방식을 쓸 때만 (KIOSK_PRESENCE=pir)
KIOSK_PIR_PIN=17
KIOSK_PIR_HOLD=8
